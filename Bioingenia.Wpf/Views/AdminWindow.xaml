<Window x:Class="Bioingenieria.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Bioingenieria.Controls"
        Title="Administración"
        Height="500" Width="700"
        MinHeight="400" MinWidth="600"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/app.ico">
    <DockPanel>
        <controls:FormHeaderControl DockPanel.Dock="Top" Title="Administración" />

        <StackPanel DockPanel.Dock="Left" Width="190" Background="White">
            <Button Content="Nuevo equipo" Style="{StaticResource SecondaryButtonStyle}" Margin="12,12,12,6" Click="NewEquipmentButton_Click" />
            <Button Content="Subir documento" Style="{StaticResource SecondaryButtonStyle}" Margin="12,6,12,6" Click="UploadDocumentButton_Click" />
            <Button Content="Gestionar usuarios" Style="{StaticResource SecondaryButtonStyle}" Margin="12,6,12,6" Click="ManageUsersButton_Click" />
            <Button Content="Cronogramas" Style="{StaticResource SecondaryButtonStyle}" Margin="12,6,12,6" Click="SchedulesButton_Click" />
        </StackPanel>

        <TreeView x:Name="EquipmentTreeView" BorderThickness="0" MouseDoubleClick="EquipmentTreeView_MouseDoubleClick" />
    </DockPanel>
</Window>

<Window x:Class="Bioingenieria.Views.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Bioingenieria.Controls"
        Title="Usuario"
        Height="368" Width="320"
        Background="{StaticResource SurfaceBrush}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/app.ico">
    <DockPanel>
        <controls:FormHeaderControl x:Name="HeaderControl" DockPanel.Dock="Top" Title="Usuario" />
        <StackPanel Margin="20">
            <TextBlock Text="Usuario" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
            <TextBox x:Name="UsernameTextBox" Height="27" Margin="0,0,0,16" />

            <TextBlock x:Name="PasswordLabel" Text="Contraseña" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
            <PasswordBox x:Name="PasswordBox" Height="27" Margin="0,0,0,16" />

            <TextBlock Text="Rol" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
            <ComboBox x:Name="RoleComboBox" Height="28" Margin="0,0,0,16" />

            <CheckBox x:Name="ActiveCheckBox" Content="Activo" Margin="0,0,0,16" />

            <TextBlock x:Name="ErrorTextBlock"
                       Foreground="{StaticResource CriticalBrush}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,0,0,16" />

            <StackPanel Orientation="Horizontal">
                <Button Content="Guardar" Style="{StaticResource PrimaryButtonStyle}" Width="130" IsDefault="True" Click="SaveButton_Click" Margin="0,0,8,0" />
                <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Width="130" IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>

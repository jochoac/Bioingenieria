<Window x:Class="Bioingenieria.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscador de Documentación por Equipo"
        Height="550" Width="900"
        MinHeight="400" MinWidth="700"
        Background="{StaticResource SurfaceBrush}"
        Icon="/Resources/app.ico">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Height="56">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="/Resources/logo.png" Width="36" Height="36" VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="Bioingenia"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="15"
                           VerticalAlignment="Center"
                           Margin="10,0,18,0" />

                <Grid Grid.Column="2" VerticalAlignment="Center" Width="260">
                    <TextBox x:Name="SearchTextBox" Height="27" VerticalContentAlignment="Center" KeyDown="SearchTextBox_KeyDown" />
                    <TextBlock Text="Buscar por número de serie..."
                               Foreground="Gray"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="3"
                        Content="Buscar"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        Click="SearchButton_Click" />

                <Button Grid.Column="5"
                        x:Name="AdminButton"
                        Content="Administración"
                        Style="{StaticResource HeaderGhostButtonStyle}"
                        VerticalAlignment="Center"
                        Click="AdminButton_Click" />
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ResultsItemsControl" Margin="12">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>

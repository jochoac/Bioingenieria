<Window x:Class="Bioingenieria.Views.UploadDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Bioingenieria.Controls"
        Title="Subir documento"
        Height="338" Width="400"
        Background="{StaticResource SurfaceBrush}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/app.ico">
    <DockPanel>
        <controls:FormHeaderControl DockPanel.Dock="Top" Title="Subir documento" />
        <StackPanel Margin="20">
            <TextBlock Text="Equipo" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
            <ComboBox x:Name="EquipmentComboBox" IsEditable="True" IsTextSearchEnabled="True" Height="28" Margin="0,0,0,16" />

            <TextBlock Text="Categoría" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
            <ComboBox x:Name="CategoryComboBox" IsEditable="True" IsTextSearchEnabled="True" Height="28" Margin="0,0,0,16" />

            <TextBlock Text="Archivo" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="FilePathTextBox" IsReadOnly="True" Height="27" Margin="0,0,8,0" />
                <Button Grid.Column="1" Content="Buscar..." Style="{StaticResource SecondaryButtonStyle}" Width="80" Click="BrowseButton_Click" />
            </Grid>

            <TextBlock x:Name="ErrorTextBlock"
                       Foreground="{StaticResource CriticalBrush}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,0,0,16" />

            <StackPanel Orientation="Horizontal">
                <Button Content="Guardar" Style="{StaticResource PrimaryButtonStyle}" Width="175" IsDefault="True" Click="SaveButton_Click" Margin="0,0,8,0" />
                <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Width="175" IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>

<UserControl x:Class="Bioingenieria.Controls.FormHeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Height="48">
    <DockPanel Background="{StaticResource PrimaryBrush}">
        <Border DockPanel.Dock="Bottom" Height="3" Background="{StaticResource AccentBrush}" />
        <TextBlock Text="{Binding Title, ElementName=Root}"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Margin="20,0" />
    </DockPanel>
</UserControl>
